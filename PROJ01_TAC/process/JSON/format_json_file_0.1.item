  <node componentName="tJavaFlex" componentVersion="0.101" offsetLabelX="0" offsetLabelY="0" posX="256" posY="128">
    <elementParameter field="TEXT" name="UNIQUE_NAME" show="false" value="tJavaFlex_1"/>
    <elementParameter field="CHECK" name="DATA_AUTO_PROPAGATE" value="false"/>
    <elementParameter field="MEMO_JAVA" name="CODE_START" value="// start part of your Java code&#10;int count=0;&#10;int rowcount=((Integer)globalMap.get(&quot;tFileRowCount_1_COUNT&quot;));&#10;  "/>
    <elementParameter field="MEMO_JAVA" name="CODE_MAIN" value="count++;&#10;if(count == 1){&#10;&#9;// first row, just add: ,&#10;&#9;json_corrected.line=input_json.line+&quot;,&quot;;&#10;} else if(count &lt; rowcount){&#10;&#9;// Put &quot; and , back in the rows&#10;&#9;json_corrected.line=&quot;\&quot;&quot;+input_json.line+&quot;,&quot;;&#10;} else {&#10;&#9;// last row, just add: &quot;&#10;&#9;json_corrected.line=&quot;\&quot;&quot;+input_json.line;&#10;}"/>
    <elementParameter field="MEMO_JAVA" name="CODE_END" value="// end of the component, outside/closing the loop&#10;      "/>
    <elementParameter field="CHECK" name="Version_V2_0" show="false" value="false"/>
    <elementParameter field="CHECK" name="Version_V3_2" show="false" value="false"/>
    <elementParameter field="CHECK" name="Version_V4.0" show="false" value="true"/>
    <elementParameter field="MEMO_IMPORT" name="IMPORT" value="//import java.util.List;"/>
    <elementParameter field="TEXT" name="LABEL" value="__UNIQUE_NAME__&lt;br&gt;&lt;b&gt;Put ,&quot; back&lt;/b&gt;"/>
    <elementParameter field="TEXT" name="CONNECTION_FORMAT" value="row"/>
    <metadata connector="FLOW" name="tJavaFlex_1">
      <column comment="" key="false" length="-1" name="line" nullable="true" originalLength="-1" pattern="" precision="-1" sourceType="" type="id_String" usefulColumn="true"/>
